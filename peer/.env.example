# PocketDoc Laptop AI Provider Configuration

# Port for the AI provider HTTP server
PROVIDER_PORT=4000

# LLM model configuration
# By default, PocketDoc uses Qwen3VL-2B (multimodal) to support camera symptom analysis offline.
# To override or change models, configure the sources below:

# Optional: Set a specific text-only or vision model.
# Defaults to QWEN3VL_2B_MULTIMODAL_Q4_K if unset.
# LLM_MODEL_SRC=https://huggingface.co/qvac/MedPsy-4B-GGUF/resolve/main/medpsy-4b-q4_k_m-imat.gguf

# Optional: Set a projection model (only required for custom multimodal vision models).
# Defaults to MMPROJ_QWEN3VL_2B_MULTIMODAL_Q4_K if using Qwen3VL.
# LLM_PROJ_SRC=https://huggingface.co/Qwen/Qwen3-VL-2B-Instruct-GGUF/resolve/main/mmproj-Qwen3VL-2B-Instruct-Q8_0.gguf
