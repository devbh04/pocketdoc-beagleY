# PocketDoc Laptop Provider Configuration

# Optional: Seed for generating a deterministic, persistent provider public key (64-character hex string)
# If left blank, QVAC will generate a random keypair on every restart
# To generate one, you can run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QVAC_HYPERSWARM_SEED=your_64_character_hex_seed_here

# Optional: Path or URL override for the delegated MedPsy-4B GGUF model
# Default if unset: https://huggingface.co/qvac/MedPsy-4B-GGUF/resolve/main/MedPsy-4B-Q4_K_M.gguf
# MEDPSY_4B_Q4=./models/MedPsy-4B-Q4_K_M.gguf
