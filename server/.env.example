# PocketDoc Server Configuration

# The port where the board HTTP + WebSocket server will listen
PORT=3000

# The public key of the laptop peer running peer/provider.js
# This is required for routing delegated inference queries (e.g. vision or complex logic)
PEER_PROVIDER_PUBLIC_KEY=your_laptop_provider_public_key_here

# Optional: Path or URL override for the local MedPsy-1.7B GGUF model
# Default if unset: https://huggingface.co/qvac/MedPsy-1.7B-GGUF/resolve/main/MedPsy-1.7B-Q4_K_M.gguf
# MEDPSY_1_7B_Q4=./models/MedPsy-1.7B-Q4_K_M.gguf
